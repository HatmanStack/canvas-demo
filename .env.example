# AWS Credentials (Lambda-compatible non-reserved names)
AMP_AWS_ID=your-aws-access-key-id
AMP_AWS_SECRET=your-aws-secret-access-key

# AWS Regions
AWS_REGION=us-east-1
BUCKET_REGION=us-west-2

# S3 Bucket for image storage and rate limiting
NOVA_IMAGE_BUCKET=your-bucket-name

# Rate Limiting (requests per 20-minute window)
RATE_LIMIT=20

# Logging
LOG_LEVEL=INFO

# NSFW Content Filtering (optional)
ENABLE_NSFW_CHECK=false
HF_TOKEN=your-huggingface-token
