# AWS Credentials (checked in this order: AMP_AWS_ID > AWS_ID > AWS_ACCESS_KEY_ID)
AMP_AWS_ID=your-access-key-id
AMP_AWS_SECRET=your-secret-access-key

# AWS Regions
AWS_REGION=us-east-1
BUCKET_REGION=us-west-2

# S3 Bucket for image storage and rate limiting
NOVA_IMAGE_BUCKET=your-bucket-name

# Rate Limiting (requests per 20-minute window)
RATE_LIMIT=20

# Logging
LOG_LEVEL=INFO

# NSFW Content Filtering (optional)
ENABLE_NSFW_CHECK=false
HF_TOKEN=your-huggingface-token

# Lambda Configuration (auto-detected, typically set by AWS)
# AWS_LAMBDA_FUNCTION_NAME=  # Presence triggers Lambda mode
# AWS_LAMBDA_HTTP_PORT=8080  # Default Lambda port

# Integration Testing
# LOCALSTACK_URL=http://localhost:4566  # Required for integration tests
